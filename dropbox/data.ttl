@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix peh: <http://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

peh:MatrixOntology a owl:Ontology ;
    peh:matrix_subclasses peh:Ethanol,
        peh:Glucose,
        peh:Water .

peh:Ethanol a owl:Class ;
    rdfs:label "Ethanol" ;
    dcterms:description "A common solvent and alcohol." ;
    rdfs:subClassOf peh:Matrix .

peh:Glucose a owl:Class ;
    rdfs:label "Glucose" ;
    dcterms:description "A simple sugar used as an energy source." ;
    rdfs:subClassOf peh:Matrix .

peh:Water a owl:Class ;
    rdfs:label "Water" ;
    dcterms:description "A simple molecule consisting of hydrogen and oxygen." ;
    peh:translations [ a peh:Translation ;
            peh:language "nl" ;
            peh:property_name "label" ;
            peh:translated_value "water" ] ;
    rdfs:subClassOf peh:Matrix .

