@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://w3id.org/peh/terms/Water> a owl:Class ;
    rdfs:label "Water",
        "water"@nl ;
    dcterms:description "A simple molecule consisting of hydrogen and oxygen." ;
    rdfs:subClassOf <http://w3id.org/peh/terms/Matrix> .

