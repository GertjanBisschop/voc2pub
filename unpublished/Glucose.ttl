@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://w3id.org/peh/terms/Glucose> a owl:Class ;
    rdfs:label "Glucose" ;
    dcterms:description "A simple sugar used as an energy source." ;
    rdfs:subClassOf <http://w3id.org/peh/terms/Matrix> .

